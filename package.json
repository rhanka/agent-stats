{
  "name": "agent-stats-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workspace root for @sentropic/agent-stats",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/agent-stats.git"
  },
  "license": "MIT",
  "author": "rhanka",
  "overrides": {
    "cookie": "^0.7.0"
  }
}
